# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                    # obligatoire — texte + audio (Groq)
GROQ_MODEL=llama-3.3-70b-versatile     # optionnel — modèle par défaut
OPENAI_API_KEY=sk-...                   # obligatoire — embeddings uniquement

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...                  # obligatoire
TELEGRAM_CHAT_ID=...                    # obligatoire — ton chat_id perso

# ── Dropbox (choisir UNE des deux méthodes) ───────────────────────────────────
# Méthode 1 — token long terme (legacy)
DROPBOX_ACCESS_TOKEN=...

# Méthode 2 — OAuth2 refresh token (recommandé)
DROPBOX_APP_KEY=...
DROPBOX_APP_SECRET=...
DROPBOX_REFRESH_TOKEN=...

# ── Optionnel ─────────────────────────────────────────────────────────────────
HEALTH_PORT=8080                        # port du serveur /health (défaut : 8080)
